projection;
strict ( 2 );
use draft;

define behavior for ZC_APG_Point
{
  use create;
  use update;
  use delete;

  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;

  use association _Gates { create; with draft; }
}

define behavior for ZC_APG_GateHandle
{
  use update;
  use delete;

  use association _Point { with draft; }
}